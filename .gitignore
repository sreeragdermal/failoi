# Dependencies
node_modules/
/backend/node_modules/
/frontend/node_modules/

# Production builds
dist/
/backend/dist/
/frontend/dist/
build/
bin/

# Coverage and caches
coverage/
.cache/
.eslintcache
.parcel-cache
.turbo
.vercel

# Environment variables (contains sensitive secrets)
.env
.env.*
!.env.example

# OS and system files
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Application uploads and processing files
/backend/uploads/pdfs/*
/backend/uploads/thumbnails/*
/backend/tmp/
tmp/
uploads/

# Keep folders structure but ignore files inside
!/backend/uploads/pdfs/.gitkeep
!/backend/uploads/thumbnails/.gitkeep

# Ignore any root level test/debug assets
*.pdf
*.png
*.jpg
*.jpeg
