# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/failoi?schema=public"

# JSON Web Token sign key (ensure this is a long random string in production)
JWT_SECRET="generate-a-secure-jwt-access-secret-key-32-chars-or-more"

# JSON Web Token refresh sign key (ensure this is a long random string in production)
JWT_REFRESH_SECRET="generate-a-secure-jwt-refresh-secret-key-32-chars-or-more"

# Port number that backend server listens to
PORT=5005

# Complete base URL for backend endpoints
BACKEND_URL="http://localhost:5005"

# Complete base URL for trusted frontend CORS origins
FRONTEND_URL="http://localhost:5173"

# Uploads directory path on the local disk
UPLOAD_DIR="./uploads"

# Optional SMTP Gateway Configuration (falls back to mocked logs if not specified)
SMTP_HOST="smtp.mailgun.org"
SMTP_PORT=587
SMTP_USER="postmaster@sandbox.mailgun.org"
SMTP_PASS="smtp_password_here"
SMTP_FROM="noreply@failoi.com"

# Google OAuth Integration Credentials
GOOGLE_CLIENT_ID="your-google-oauth-client-id-here.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret-here"
GOOGLE_REDIRECT_URI="http://localhost:5005/api/v1/auth/google/callback"

