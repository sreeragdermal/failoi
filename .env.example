# Failoi Root Environment Configuration Template

# Refer to backend/.env.example for backend configs
# Refer to frontend/src/services/api.ts for client endpoints config

# Backend env parameters
DATABASE_URL="postgresql://username:password@localhost:5432/failoi?schema=public"
JWT_SECRET="your-jwt-access-token-secret"
JWT_REFRESH_SECRET="your-jwt-refresh-token-secret"
PORT=5005
BACKEND_URL="http://localhost:5005"
FRONTEND_URL="http://localhost:5173"
UPLOAD_DIR="./uploads"

# SMTP Settings
SMTP_HOST="smtp.mailgun.org"
SMTP_PORT=587
SMTP_USER="postmaster@sandbox.mailgun.org"
SMTP_PASS="smtp_password_here"
SMTP_FROM="noreply@failoi.com"
